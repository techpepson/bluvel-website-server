datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  service   String
  budget    String?
  message   String
  createdAt DateTime @default(now())
}
